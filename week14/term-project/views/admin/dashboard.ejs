<!doctype html>
<html>
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
    <style>
      :root{--emerald:#0b6b52;--gold:#c99a3b}
      body{font-family:'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;padding:28px;background:linear-gradient(180deg,#f7fbfa,#eef6f4)}
      header{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
      h1{font-family:'Playfair Display', Georgia, serif;margin:0;color:#072a22}
      .logout{color:var(--emerald);text-decoration:none;font-weight:600}
      .card{background:linear-gradient(180deg,rgba(255,255,255,0.95),rgba(255,255,250,0.95));padding:18px;border-radius:12px;border:1px solid rgba(11,107,82,0.06);box-shadow:0 8px 20px rgba(10,30,20,0.06)}
      table{width:100%;border-collapse:collapse;margin-top:12px;background:transparent}
      thead th{background:transparent;text-align:left;padding:12px 10px;color:#234b42;font-weight:700}
      tbody td{padding:14px 10px;border-top:1px solid rgba(11,107,82,0.06);vertical-align:top}
      .name-col{width:220px;font-weight:600;color:#07332b}
      pre{white-space:pre-wrap;font-family:Menlo,Monaco,monospace;background:transparent;border:none;margin:0;color:#243a36}
      @media (max-width:720px){body{padding:16px}.name-col{width:140px}}
    </style>
  </head>
  <body>
    <header>
      <div>
        <h1>Kai Nani - Admin</h1>
        <div>Welcome, <strong><%= user && user.email %></strong></div>
      </div>
      <div><a class="logout" href="/admin/logout">Logout</a></div>
    </header>

    <section>
      <h2>Properties</h2>
      <table>
        <thead>
          <tr><th>Name</th><th>Details</th></tr>
        </thead>
        <tbody>
          <% properties.forEach(function(p){ %>
            <tr>
              <td><%= p.name || p.title || 'Untitled' %></td>
              <td><pre style="margin:0"><%= JSON.stringify(p, null, 2) %></pre></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </body>
</html>
